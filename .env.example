JWT_SECRET_KEY=replace-with-a-long-random-secret
LISTEN_ADDRESS=127.0.0.1
LISTEN_PORT=3030

APP_ENV=development
DEBUG=true

DATABASE_NAME=gradeomatic
DATABASE_USER=gradeomatic
DATABASE_PASSWORD=replace-with-local-db-password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# You can set DATABASE_URL directly instead of DATABASE_* parts.
DATABASE_URL="postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"

OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_REDIRECT_URL=

# RUST_LOG format: crate1=level1,crate2=level2,...
RUST_LOG=info,sqlx=debug,tower_http=info,axum::rejection=trace,opentelemetry=info

# Asset Config
ASSETS_HOME_PATH=assets
ASSETS_PUBLIC_PATH=${ASSETS_HOME_PATH}/public
ASSETS_PUBLIC_URL=/assets/public
ASSETS_PRIVATE_PATH=${ASSETS_HOME_PATH}/private
ASSETS_PRIVATE_URL=/assets/private

# 50MB: 50 * 1024 * 1024 = 52428800
ASSET_MAX_SIZE=52428800
ASSET_ALLOWED_EXTENSIONS=jpg|jpeg|png|gif|webp|svg|pdf|doc|docx|ppt|pptx|xls|xlsx|hwp|hwpx|txt|zip

# OpenTelemetry OTLP Exporter
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# CI/test defaults (already configured in workflow/test helpers)
SQLX_OFFLINE=true
